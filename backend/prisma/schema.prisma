generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClimbResult {
  ATTEMPTED
  WORKING
  ALMOST
  COMPLETED
  FLASH
  ONSIGHT
  REPEAT
  PROJECT
  COMPETITION_SEND
  PERSONAL_BEST
}

enum MediaType {
  PHOTO
  VIDEO
}

enum WallAngle {
  SLAB
  VERTICAL
  SLIGHT_OVERHANG
  OVERHANG
  STEEP
  ROOF
}

enum PrivacyLevel {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

enum VerificationMethod {
  SELF_REPORTED
  FRIEND_VERIFIED
  VIDEO_VERIFIED
  GYM_VERIFIED
  COMMUNITY_VERIFIED
}

model User {
  id                      String       @id @default(cuid())
  username                String       @unique
  email                   String       @unique
  passwordHash            String
  displayName             String
  bio                     String?
  profileImageUrl         String?
  homeGymId               String?
  location                String?
  yearsClimbing           Int?
  height                  Int?
  apeIndex                Int?
  preferredStyle          String?
  currentProjectGrade     String?
  hardestSend             String?
  hardestFlash            String?
  gymGrade                String?
  outdoorGrade            String?
  favoriteWallAngle       String?
  favoriteHoldType        String?
  preferredClimbingStyle  String?
  privacy                 PrivacyLevel @default(PUBLIC)
  climberRating           Float        @default(0)
  xpPoints                Int          @default(0)
  level                   Int          @default(1)
  consistencyStreak       Int          @default(0)
  longestStreak           Int          @default(0)
  lastClimbDate           DateTime?
  totalSends              Int          @default(0)
  totalAttempts           Int          @default(0)
  totalFlashes            Int          @default(0)
  totalSessions           Int          @default(0)
  pushToken               String?
  isVerifiedGymAccount    Boolean      @default(false)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  homeGym                 Gym?                 @relation("HomeGym", fields: [homeGymId], references: [id])
  climbs                  Climb[]
  sessions                Session[]
  achievements            UserAchievement[]
  followers               Follow[]             @relation("Following")
  following               Follow[]             @relation("Follower")
  comments                Comment[]
  likes                   Like[]
  notifications           Notification[]
  ratings                 Rating[]
  challenges              UserChallenge[]
  refreshTokens           RefreshToken[]
  media                   Media[]
  checkIns                CheckIn[]
  sentCongratulations     Congratulation[]     @relation("SentCongrats")
  receivedCongratulations Congratulation[]     @relation("ReceivedCongrats")

  @@index([username])
  @@index([email])
  @@index([climberRating])
}

model Gym {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String
  city        String
  state       String?
  country     String
  latitude    Float?
  longitude   Float?
  website     String?
  phone       String?
  instagram   String?
  imageUrl    String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  totalRoutes Int      @default(0)
  totalSends  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  walls     Wall[]
  routes    Route[]
  homeUsers User[]    @relation("HomeGym")
  checkIns  CheckIn[]
  sessions  Session[]

  @@index([city])
  @@index([country])
}

model Wall {
  id          String    @id @default(cuid())
  gymId       String
  name        String
  angle       WallAngle
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  gym    Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  routes Route[]

  @@index([gymId])
}

model Route {
  id              String     @id @default(cuid())
  gymId           String
  wallId          String?
  name            String?
  grade           String
  color           String
  setterId        String?
  setterName      String?
  dateSet         DateTime
  expectedRemoval DateTime?
  isActive        Boolean    @default(true)
  wallAngle       WallAngle?
  holdStyle       String?
  isCompetition   Boolean    @default(false)
  description     String?
  totalAttempts   Int        @default(0)
  totalSends      Int        @default(0)
  flashCount      Int        @default(0)
  avgDifficulty   Float?
  avgFun          Float?
  avgRating       Float?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  gym      Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  wall     Wall?     @relation(fields: [wallId], references: [id])
  climbs   Climb[]
  media    Media[]
  ratings  Rating[]
  comments Comment[]

  @@index([gymId])
  @@index([grade])
  @@index([isActive])
}

model Climb {
  id                 String              @id @default(cuid())
  userId             String
  routeId            String
  gymId              String
  sessionId          String?
  result             ClimbResult
  attempts           Int                 @default(1)
  notes              String?
  difficultyRating   Int?
  enjoymentRating    Int?
  isVerified         Boolean             @default(false)
  verificationMethod VerificationMethod?
  isCompetitionSend  Boolean             @default(false)
  agreeWithGrade     Boolean?
  perceivedGrade     String?
  isPublic           Boolean             @default(true)
  likeCount          Int                 @default(0)
  commentCount       Int                 @default(0)
  date               DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  route           Route            @relation(fields: [routeId], references: [id])
  session         Session?         @relation(fields: [sessionId], references: [id])
  media           Media[]
  likes           Like[]
  comments        Comment[]
  congratulations Congratulation[]

  @@index([userId])
  @@index([routeId])
  @@index([gymId])
  @@index([date])
  @@index([result])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  gymId      String
  startTime  DateTime
  endTime    DateTime?
  duration   Int?
  notes      String?
  climbCount Int       @default(0)
  sendCount  Int       @default(0)
  createdAt  DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym    Gym     @relation(fields: [gymId], references: [id])
  climbs Climb[]

  @@index([userId])
  @@index([gymId])
}

model Media {
  id           String    @id @default(cuid())
  userId       String
  climbId      String?
  routeId      String?
  type         MediaType
  url          String
  thumbnailUrl String?
  size         Int?
  width        Int?
  height       Int?
  duration     Int?
  isBeta       Boolean   @default(false)
  caption      String?
  createdAt    DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  climb Climb? @relation(fields: [climbId], references: [id])
  route Route? @relation(fields: [routeId], references: [id])

  @@index([userId])
  @@index([climbId])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String
  category    String
  criteria    Json
  xpReward    Int      @default(100)
  rarity      String   @default("common")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  climbId   String?
  routeId   String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  climb Climb? @relation(fields: [climbId], references: [id])
  route Route? @relation(fields: [routeId], references: [id])

  @@index([climbId])
  @@index([userId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  climbId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  climb Climb @relation(fields: [climbId], references: [id], onDelete: Cascade)

  @@unique([userId, climbId])
  @@index([climbId])
}

model Congratulation {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  climbId    String
  message    String?
  createdAt  DateTime @default(now())

  fromUser User  @relation("SentCongrats", fields: [fromUserId], references: [id])
  toUser   User  @relation("ReceivedCongrats", fields: [toUserId], references: [id])
  climb    Climb @relation(fields: [climbId], references: [id])

  @@unique([fromUserId, climbId])
}

model Rating {
  id              String   @id @default(cuid())
  userId          String
  routeId         String
  difficulty      Int?
  fun             Int?
  creativity      Int?
  skinFriendly    Int?
  quality         Int?
  holdQuality     Int?
  movementQuality Int?
  overall         Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([userId, routeId])
  @@index([routeId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Challenge {
  id          String    @id @default(cuid())
  name        String
  description String
  type        String
  criteria    Json
  startDate   DateTime?
  endDate     DateTime?
  xpReward    Int       @default(200)
  isActive    Boolean   @default(true)
  isRecurring Boolean   @default(false)
  imageUrl    String?
  createdAt   DateTime  @default(now())

  participants UserChallenge[]
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  progress    Json      @default("{}")
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  joinedAt    DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  gymId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id])

  @@index([userId])
  @@index([gymId])
}
